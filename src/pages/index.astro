---
import '../styles/global.css';

const steps = ['Petición', 'Investigación mínima', 'Decisión', 'PRP Lite', 'Prompt XML', 'Validación'];
const cards = [
  ['Contexto mínimo', 'Separa hechos, inferencias, dudas y decisiones antes de pedir código.'],
  ['Alcance cerrado', 'Define qué puede tocar el agente, qué no debe tocar y cómo revisar el diff.'],
  ['Validación clara', 'Convierte tests, build, lint y smoke checks en criterios de terminado.'],
];
---

<html lang="es" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PRP Lite — Razonar primero. Ejecutar después.</title>
    <meta name="description" content="PRP Lite convierte ideas, bugs e issues en decisiones claras, planes cortos y prompts XML ejecutables." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-openai-light text-gray-800 dark:bg-openai-darker dark:text-gray-200 min-h-screen selection:bg-openai-green selection:text-white transition-colors duration-200">
    <main class="max-w-4xl mx-auto px-6 py-12 md:py-20 flex flex-col gap-16">
      
      <header class="flex items-center justify-between">
        <a class="flex items-center gap-3 no-underline group" href="/PRP-LITE/">
          <div class="w-8 h-8 rounded bg-openai-green flex items-center justify-center text-white font-bold text-lg group-hover:bg-opacity-90 transition-colors">P</div>
          <div class="flex flex-col">
            <strong class="text-gray-900 dark:text-white leading-tight">PRP Lite</strong>
            <span class="text-xs text-gray-500 dark:text-gray-400">ChatGPT primero · agente después</span>
          </div>
        </a>
        <a class="text-sm font-medium px-4 py-2 rounded-md border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-openai-dark transition-colors" href="https://github.com/YampiSLabs/PRP-LITE" target="_blank" rel="noreferrer">
          GitHub
        </a>
      </header>

      <section class="flex flex-col gap-6 md:gap-8 items-start">
        <span class="inline-block px-3 py-1 rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100 text-xs font-semibold tracking-wide uppercase">Framework ligero para agentes</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white tracking-tight max-w-3xl">
          Convierte ruido en una tarea ejecutable.
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl leading-relaxed">
          PRP Lite ordena una idea, bug o feature antes de pasarla a un agente. Primero cierra problema, contexto, decisión, alcance y validación. Después genera un prompt XML compacto.
        </p>
        <div class="flex flex-wrap gap-4 mt-4">
          <a href="#workflow" class="px-6 py-3 rounded-md bg-openai-green text-gray-900 font-bold hover:bg-opacity-90 transition-colors shadow-sm">Ver flujo →</a>
          <a href="#stack" class="px-6 py-3 rounded-md border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-openai-dark transition-colors font-medium">Qué incluye</a>
        </div>
      </section>

      <div class="h-px w-full bg-gray-200 dark:bg-gray-800"></div>

      <section id="stack" class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {cards.map(([title, body]) => (
          <article class="flex flex-col gap-3">
            <div class="w-10 h-10 rounded-md bg-green-50 dark:bg-openai-dark flex items-center justify-center text-openai-green text-xl font-bold border border-green-100 dark:border-gray-700">✓</div>
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{title}</h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">{body}</p>
          </article>
        ))}
      </section>

      <section class="flex flex-col md:flex-row gap-12 mt-8">
        <div class="flex-1">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Flujo PRP Lite</h2>
          <ol class="flex flex-col gap-4">
            {steps.map((step, index) => (
              <li class="flex items-center gap-4 p-4 rounded-lg bg-gray-50 dark:bg-openai-dark border border-gray-100 dark:border-gray-800">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-white dark:bg-openai-darker text-sm font-bold text-gray-900 dark:text-white border border-gray-200 dark:border-gray-700 shadow-sm">{index + 1}</span>
                <span class="font-medium text-gray-800 dark:text-gray-200">{step}</span>
              </li>
            ))}
          </ol>
        </div>
        
        <div class="flex-1" id="workflow">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Uso recomendado</h2>
          <div class="flex flex-col gap-6">
            <p class="text-lg text-gray-700 dark:text-gray-300"><strong>Razonar primero. Compactar después. Ejecutar solo cuando esté claro.</strong></p>
            <ul class="flex flex-col gap-5 text-gray-600 dark:text-gray-400 list-disc pl-5">
              <li><strong>1.</strong> Investiga lo mínimo para no inventar archivos, APIs ni comandos.</li>
              <li><strong>2.</strong> Cierra enfoque, alcance, riesgos aceptados y validación mínima.</li>
              <li><strong>3.</strong> Entrega un prompt XML con tarea, contexto, scope, restricciones, pasos y output.</li>
            </ul>
          </div>
        </div>
      </section>
      
      <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 text-center text-sm text-gray-600 dark:text-gray-400">
        Hecho para equipos que quieren pensar mejor antes de delegar ejecución.
      </footer>
    </main>
  </body>
</html>
