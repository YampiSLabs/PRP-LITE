---
import '../styles/global.css';

const steps = ['Petición', 'Investigación mínima', 'Decisión', 'PRP Lite', 'Prompt XML', 'Validación'];
const cards = [
  ['Contexto mínimo', 'Separa hechos, inferencias, dudas y decisiones antes de pedir código.'],
  ['Alcance cerrado', 'Define qué puede tocar el agente, qué no debe tocar y cómo revisar el diff.'],
  ['Validación clara', 'Convierte tests, build, lint y smoke checks en criterios de terminado.'],
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PRP Lite — Razonar primero. Ejecutar después.</title>
    <meta name="description" content="PRP Lite convierte ideas, bugs e issues en decisiones claras, planes cortos y prompts XML ejecutables." />
  </head>
  <body>
    <main class="shell">
      <header class="topbar glass">
        <a class="brand" href="/PRP-LITE/">
          <span class="mark">✦</span>
          <span><strong>PRP Lite</strong><small>ChatGPT primero · agente después</small></span>
        </a>
        <a class="button ghost" href="https://github.com/YampiSLabs/PRP-LITE" target="_blank" rel="noreferrer">GitHub</a>
      </header>

      <section class="hero">
        <div>
          <p class="eyebrow glass">Framework ligero para agentes</p>
          <h1>Convierte ruido en una tarea ejecutable.</h1>
          <p class="lead">PRP Lite ordena una idea, bug o feature antes de pasarla a un agente. Primero cierra problema, contexto, decisión, alcance y validación. Después genera un prompt XML compacto.</p>
          <div class="actions">
            <a href="#workflow" class="button primary">Ver flujo →</a>
            <a href="#stack" class="button ghost">Qué incluye</a>
          </div>
        </div>

        <aside class="panel glass">
          <div class="panel-title"><strong>Flujo PRP Lite</strong><span>limpio y directo</span></div>
          <ol class="steps">
            {steps.map((step, index) => <li><b>{String(index + 1).padStart(2, '0')}</b><span>{step}</span></li>)}
          </ol>
        </aside>
      </section>

      <section class="cards" id="stack">
        {cards.map(([title, body]) => (
          <article class="card glass">
            <span class="mark small">✦</span>
            <h2>{title}</h2>
            <p>{body}</p>
          </article>
        ))}
      </section>

      <section class="workflow glass" id="workflow">
        <p class="eyebrow inline">Uso recomendado</p>
        <h2>Razonar primero. Compactar después. Ejecutar solo cuando esté claro.</h2>
        <div class="workflow-grid">
          <p><strong>1.</strong> Investiga lo mínimo para no inventar archivos, APIs ni comandos.</p>
          <p><strong>2.</strong> Cierra enfoque, alcance, riesgos aceptados y validación mínima.</p>
          <p><strong>3.</strong> Entrega un prompt XML con tarea, contexto, scope, restricciones, pasos y output.</p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; background: #050505; }
  :global(body) {
    min-height: 100vh; margin: 0; color: #f5f5f0;
    background: radial-gradient(circle at top left, rgba(68,207,157,.18), transparent 34rem), radial-gradient(circle at 85% 12%, rgba(255,255,255,.12), transparent 26rem), linear-gradient(180deg,#050505 0%,#10100f 48%,#050505 100%);
    font-family: 'Inter', system-ui, sans-serif;
  }
  :global(a) { color: inherit; }
  .shell { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 24px 0 72px; }
  .glass { border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.055); box-shadow: 0 24px 90px rgba(0,0,0,.34); backdrop-filter: blur(22px); }
  .topbar, .brand, .button, .steps li { display: flex; align-items: center; }
  .topbar { justify-content: space-between; gap: 16px; border-radius: 999px; padding: 12px 14px; }
  .brand { gap: 12px; text-decoration: none; }
  .brand strong { display: block; color: #fff; }
  .brand small { display: block; margin-top: 2px; color: #a3a39c; font-size: 12px; }
  .mark { display: inline-grid; place-items: center; width: 42px; height: 42px; flex: 0 0 auto; border-radius: 15px; color: #9df2c9; background: rgba(157,242,201,.1); border: 1px solid rgba(157,242,201,.2); }
  .mark.small { width: 48px; height: 48px; border-radius: 18px; }
  .button { gap: 10px; border-radius: 999px; padding: 13px 18px; text-decoration: none; font-size: 14px; font-weight: 700; transition: transform .16s ease, background .16s ease; }
  .button:hover { transform: translateY(-1px); }
  .button.primary { color: #050505; background: #f5f5f0; }
  .button.ghost { color: #f5f5f0; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); }
  .hero { display: grid; grid-template-columns: minmax(0,1.08fr) minmax(340px,.92fr); gap: 36px; align-items: center; padding: 88px 0 40px; }
  .eyebrow { width: fit-content; margin: 0 0 18px; border-radius: 999px; padding: 8px 12px; color: #9df2c9; font-size: 12px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .eyebrow.inline { display: inline-flex; background: rgba(157,242,201,.08); }
  h1, h2 { margin: 0; color: #fff; font-family: 'Plus Jakarta Sans','Inter',system-ui,sans-serif; letter-spacing: -.055em; }
  h1 { max-width: 10.4ch; font-size: clamp(3.4rem,8vw,6.8rem); line-height: .9; }
  h2 { font-size: clamp(2rem,4vw,3.5rem); line-height: .96; }
  .lead { max-width: 62ch; margin: 24px 0 0; color: #d2d2cb; font-size: 18px; line-height: 1.75; }
  .actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 30px; }
  .panel, .card, .workflow { border-radius: 30px; padding: 26px; }
  .panel-title { display: flex; justify-content: space-between; gap: 16px; margin-bottom: 18px; color: #fff; }
  .panel-title span { color: #9df2c9; font-size: 12px; font-weight: 700; }
  .steps { display: grid; gap: 10px; list-style: none; margin: 0; padding: 0; }
  .steps li { gap: 14px; border: 1px solid rgba(255,255,255,.08); border-radius: 18px; padding: 14px 16px; background: rgba(0,0,0,.24); }
  .steps b { display: grid; place-items: center; width: 38px; height: 38px; border-radius: 999px; color: #fff; background: rgba(255,255,255,.1); }
  .cards { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 18px; margin-top: 18px; }
  .card h2 { margin-top: 18px; font-size: 20px; letter-spacing: -.03em; }
  .card p, .workflow p { color: #c8c8c1; line-height: 1.7; }
  .workflow { margin-top: 18px; }
  .workflow-grid { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 14px; margin-top: 24px; }
  .workflow-grid p { margin: 0; border-radius: 22px; padding: 18px; background: rgba(0,0,0,.2); border: 1px solid rgba(255,255,255,.08); }
  .workflow-grid strong { color: #fff; }
  @media (max-width: 900px) { .hero, .cards, .workflow-grid { grid-template-columns: 1fr; } h1 { max-width: none; } }
  @media (max-width: 580px) { .shell { width: min(100% - 22px,1180px); padding-top: 12px; } .topbar { align-items: flex-start; border-radius: 26px; flex-direction: column; } .hero { padding-top: 54px; } .panel, .card, .workflow { border-radius: 24px; padding: 20px; } }
</style>
