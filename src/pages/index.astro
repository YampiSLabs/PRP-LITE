---
import '../styles/global.css';
const githubSvg = `<svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.2 1.87.86 2.33.65.07-.52.28-.86.51-1.06-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.58.82-2.14-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.26.82 2.14 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.06-.01 1.92-.01 2.18 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>`;
const arrowSvg = `<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;
const sparklesSvg = `<svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2.5 11 7l4.5 1.5L11 10l-1.5 4.5L8 10 3.5 8.5 8 7z"/><path d="M17 12l.7 2.3L20 15l-2.3.7L17 18l-.7-2.3L14 15l2.3-.7z"/></svg>`;
const cpuSvg = `<svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="2"/><path d="M9 2v4M15 2v4M9 18v4M15 18v4M2 9h4M2 15h4M18 9h4M18 15h4"/></svg>`;
const layersSvg = `<svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 17 9 5 9-5"/></svg>`;
const workflowSvg = `<svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5h18"/><path d="M7 5v14"/><path d="M17 5v14"/><path d="M7 12h10"/></svg>`;
const shieldSvg = `<svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 20 5v6c0 5-3.5 9.5-8 11-4.5-1.5-8-6-8-11V5l8-3Z"/><path d="m9 12 2 2 4-5"/></svg>`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PRP Lite — OpenAI-style landing</title>
    <meta name="description" content="PRP Lite convierte ideas, bugs e issues en decisiones claras, planes cortos y prompts XML ejecutables." />
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <main class="mx-auto min-h-screen max-w-7xl px-6 pb-16 pt-8 sm:px-8 lg:px-10">
      <header class="flex items-center justify-between gap-4 rounded-full border border-white/10 bg-white/5 px-5 py-3 backdrop-blur">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-emerald-400/15 text-emerald-300 ring-1 ring-emerald-400/20" set:html={sparklesSvg}></div>
          <div>
            <div class="text-sm font-semibold tracking-tight">PRP Lite</div>
            <div class="text-xs text-slate-400">ChatGPT primero · agente después</div>
          </div>
        </div>
        <a class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200 transition hover:bg-white/10" href="https://github.com/YampiSLabs/PRP-LITE" target="_blank" rel="noreferrer"><span set:html={githubSvg}></span> GitHub</a>
      </header>

      <section class="grid items-center gap-10 py-16 lg:grid-cols-[1.1fr_.9fr] lg:py-24">
        <div>
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs font-medium text-emerald-300" set:html={cpuSvg}>
            Carpeta plana de razonamiento
          </div>
          <h1 class="max-w-4xl text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl">Convierte ruido en una tarea ejecutable.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">PRP Lite usa Markdown para ordenar contexto, cerrar decisiones y entregar prompts XML compactos a otro agente. Menos ambigüedad. Más ejecución.</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#workflow" class="inline-flex items-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-200">Ver flujo <span set:html={arrowSvg}></span></a>
            <a href="#files" class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Explorar archivos <span set:html={workflowSvg}></span></a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-white/10 bg-white/[0.04] p-6 shadow-glow backdrop-blur-xl">
          <div class="mb-5 flex items-center justify-between">
            <div>
              <div class="text-sm font-semibold">Flujo central</div>
              <div class="text-xs text-slate-400">Desde idea hasta validación</div>
            </div>
            <div class="rounded-full bg-emerald-400/10 px-3 py-1 text-xs text-emerald-300 ring-1 ring-emerald-400/20">OpenAI style</div>
          </div>
          <div class="space-y-3">
            <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-black/20 px-4 py-4"><div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">1</div><div class="text-sm text-slate-200">Idea / issue / bug</div></div>
            <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-black/20 px-4 py-4"><div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">2</div><div class="text-sm text-slate-200">Investigación mínima</div></div>
            <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-black/20 px-4 py-4"><div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">3</div><div class="text-sm text-slate-200">PRP Lite</div></div>
            <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-black/20 px-4 py-4"><div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">4</div><div class="text-sm text-slate-200">Decisión y plan corto</div></div>
            <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-black/20 px-4 py-4"><div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">5</div><div class="text-sm text-slate-200">Prompt XML final</div></div>
            <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-black/20 px-4 py-4"><div class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white">6</div><div class="text-sm text-slate-200">Agente ejecutor + validación</div></div>
          </div>
        </div>
      </section>

      <section class="grid gap-5 md:grid-cols-3" id="files">
        <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-6" set:html={layersSvg}><h2 class="mt-4 text-lg font-semibold">Qué resuelve</h2><p class="mt-3 text-sm leading-7 text-slate-300">Tareas con objetivo borroso, alcance inflado o validación ausente.</p></div>
        <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-6" set:html={workflowSvg}><h2 class="mt-4 text-lg font-semibold">Qué contiene</h2><p class="mt-3 text-sm leading-7 text-slate-300">AGENTS.md, plantillas, checklists y ejemplo. Todo listo para ChatGPT o agentes externos.</p></div>
        <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-6" set:html={shieldSvg}><h2 class="mt-4 text-lg font-semibold">Qué produce</h2><p class="mt-3 text-sm leading-7 text-slate-300">Decisiones cerradas, contexto mínimo, alcance permitido y validación concreta.</p></div>
      </section>

      <section id="workflow" class="mt-5 grid gap-5 lg:grid-cols-[.85fr_1.15fr]">
        <div class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
          <h2 class="text-2xl font-semibold tracking-tight">Uso recomendado</h2>
          <p class="mt-3 text-sm leading-7 text-slate-300">Sube los Markdown a tu carpeta de ChatGPT, usa AGENTS.md o 00_INSTRUCTIONS.md y pide primero el PRP Lite.</p>
        </div>
        <div class="rounded-[1.75rem] border border-white/10 bg-gradient-to-br from-white/8 to-white/3 p-6">
          <div class="flex items-center gap-2 text-sm font-semibold text-slate-200" set:html={sparklesSvg}>Estilo OpenAI</div>
          <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">Fondo oscuro, contraste limpio, bordes suaves, tipografía grande y foco en una sola idea: reducir ambigüedad antes de delegar ejecución.</p>
        </div>
      </section>
    </main>
  </body>
</html>
